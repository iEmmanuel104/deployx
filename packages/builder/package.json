{
  "name": "@deployx/builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ignore-pattern '**/__tests__/**'",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@deployx/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
