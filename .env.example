# DeployX Platform Configuration
PLATFORM_DOMAIN=deployx.example.com
ENCRYPTION_KEY=                    # 64 hex chars (openssl rand -hex 32)
JWT_SECRET=                        # 64 hex chars (openssl rand -hex 32)
DB_PATH=/data/platform.db
PORT=3001
NODE_ENV=production
ACME_EMAIL=admin@example.com
DEPLOYX_VERSION=latest
