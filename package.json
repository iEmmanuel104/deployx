{
  "name": "deployx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight, open-source, self-hosted PaaS",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm -F @deployx/db generate",
    "db:migrate": "pnpm -F @deployx/db migrate"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
